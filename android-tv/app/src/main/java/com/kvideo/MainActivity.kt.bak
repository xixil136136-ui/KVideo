package com.kvideo

import android.annotation.SuppressLint
import android.app.AlertDialog
import android.content.Context
import android.content.res.Configuration
import android.graphics.Bitmap
import android.graphics.Color
import android.graphics.Typeface
import android.graphics.drawable.GradientDrawable
import android.net.ConnectivityManager
import android.net.NetworkCapabilities
import android.net.http.SslError
import android.os.Build
import android.os.Bundle
import android.os.Handler
import android.os.Looper
import android.util.Log
import android.view.Gravity
import android.view.KeyEvent
import android.view.View
import android.view.WindowManager
import android.webkit.ConsoleMessage
import android.webkit.JavascriptInterface
import android.webkit.RenderProcessGoneDetail
import android.webkit.SslErrorHandler
import android.webkit.WebChromeClient
import android.webkit.WebResourceError
import android.webkit.WebResourceRequest
import android.webkit.WebSettings
import android.webkit.WebView
import android.webkit.WebViewClient
import android.widget.Button
import android.widget.EditText
import android.widget.FrameLayout
import android.widget.ImageView
import android.widget.ProgressBar
import android.widget.TextView
import androidx.activity.ComponentActivity
import androidx.appcompat.widget.SwitchCompat
import java.lang.reflect.Proxy as ReflectProxy

class MainActivity : ComponentActivity() {

    companion object {
        private const val KVIDEO_URL = "https://xixil.cc.cd"
        private const val TAG = "KVideo"
        // Slower devices (Android < 8.0) get 60s timeout, faster ones 30s
        private val WHITE_SCREEN_TIMEOUT_MS = if (Build.VERSION.SDK_INT < 26) 60000L else 30000L
        private const val MIN_WEBVIEW_VERSION = 55
    }

    private lateinit var webView: WebView
    private lateinit var progressBar: ProgressBar
    private lateinit var errorView: TextView
    private lateinit var rootLayout: FrameLayout
    private lateinit var splashView: ImageView
    private lateinit var settingsBtn: Button
    private var loadAttempts = 0
    private val maxLoadAttempts = 4  // One extra retry for old/slow devices
    private var hasContentLoaded = false
    private val mainHandler = Handler(Looper.getMainLooper())
    private var whiteScreenChecker: Runnable? = null
    private var isTvDevice = false
    private var webViewVersion = 0
    private lateinit var proxySettings: ProxySettings

    inner class JSConsoleBridge {
        @JavascriptInterface
        fun log(msg: String) {
            Log.d(TAG, "[JS] $msg")
        }
        @JavascriptInterface
        fun error(msg: String) {
            Log.e(TAG, "[JS] $msg")
            mainHandler.post {
                if (!hasContentLoaded) {
                    errorView.text = "JS: $msg"
                    errorView.visibility = View.VISIBLE
                }
            }
        }
        @JavascriptInterface
        fun pageReady() {
            Log.d(TAG, "[JS] 页面汇报就绪")
            hasContentLoaded = true
            mainHandler.post {
                whiteScreenChecker?.let { mainHandler.removeCallbacks(it) }
                errorView.visibility = View.GONE
                splashView.visibility = View.GONE
                progressBar.visibility = View.GONE
                settingsBtn.visibility = View.GONE
            }
        }
        @JavascriptInterface
        fun webViewTooOld() {
            val ver = webViewVersion
            mainHandler.post {
                showError(
                    "⚠️ 系统WebView版本过旧 ($ver)\n\n" +
                    "当前网站需要较新的WebView支持\n\n" +
                    "建议：\n" +
                    "1️⃣ 在电视应用商店搜索更新\n" +
                    "   \"Android System WebView\"\n" +
                    "2️⃣ 或安装当贝市场/沙发管家\n" +
                    "3️⃣ 如无法更新，换安卓9+盒子\n\n" +
                    "按确定键仍尝试加载"
                )
            }
        }
    }

    private fun isTv(context: Context): Boolean {
        val uiMode = context.resources.configuration.uiMode and
                Configuration.UI_MODE_TYPE_MASK
        return uiMode == Configuration.UI_MODE_TYPE_TELEVISION
    }

    private fun isNetworkAvailable(): Boolean {
        val cm = getSystemService(Context.CONNECTIVITY_SERVICE) as ConnectivityManager
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.M) {
            val network = cm.activeNetwork ?: return false
            val caps = cm.getNetworkCapabilities(network) ?: return false
            return caps.hasCapability(NetworkCapabilities.NET_CAPABILITY_INTERNET)
        }
        return true
    }

    /**
     * Detect WebView version via reflection on WebViewFactory.
     * Android 6.0 TVs often ship with very old Chromium WebView (v50-60).
     */
    private fun detectWebViewVersion(): Int {
        return try {
            val wvfClass = Class.forName("android.webkit.WebViewFactory")
            val method = wvfClass.getDeclaredMethod("getLoadedPackageInfo")
            method.isAccessible = true
            val pkgInfo = method.invoke(null)
            val versionNameField = pkgInfo.javaClass.getDeclaredField("versionName")
            versionNameField.isAccessible = true
            val versionStr = versionNameField.get(pkgInfo) as? String ?: "0"
            val majorVer = versionStr.split(".").firstOrNull()?.toIntOrNull() ?: 0
            Log.d(TAG, "WebView version: $versionStr (major=$majorVer)")
            majorVer
        } catch (e: Exception) {
            Log.w(TAG, "Could not detect WebView version: ${e.message}")
            0
        }
    }

    /**
     * Generate a list of UA strings to try in fallback order.
     * Old WebViews may not render well with fake Chrome/124 UA.
     */
    private fun generateFallbackUAs(baseUA: String): List<String> {
        val uas = mutableListOf<String>()

        // 1. Modern Chrome (default) - works if WebView is new enough
        val modern = baseUA
            .replace(Regex(" wv"), "")
            .replace(Regex("Version/\\d+(\\.\\d+)*"), "Chrome/124")
            .replace(Regex("(?i)Leanback|SmartTV|Android TV|TV"), "")
            .trim()
        uas.add(modern)

        // 2. Conservative Chrome for old WebViews - match actual WebView version
        if (webViewVersion > 0) {
            val conservative = baseUA
                .replace(Regex(" wv"), "")
                .replace(Regex("Version/\\d+(\\.\\d+)*"), "Chrome/$webViewVersion")
                .replace(Regex("(?i)Leanback|SmartTV|Android TV|TV"), "")
                .trim()
            if (conservative != modern) uas.add(conservative)
        }

        // 3. AppleWebKit fallback - some old sites work better with Safari-like UA
        val safariLike = baseUA
            .replace(Regex(" wv"), "")
            .replace(Regex("Version/\\d+(\\.\\d+)*"), "Version/13.0")
            .replace(Regex("Chrome/\\S+"), "Safari/604.1")
            .replace(Regex("(?i)Leanback|SmartTV|Android TV|TV"), "")
            .trim()
        uas.add(safariLike)

        return uas.distinct()
    }

    /**
     * Attempt to set proxy on Chromium WebView via reflection.
     * This is the approach used by many Chinese Android streaming apps
     * and works on most Android 5+ devices with Chromium WebView.
     */
    private fun applyProxyToWebView() {
        if (!proxySettings.enabled) return

        val host = proxySettings.host
        val port = proxySettings.port

        Log.d(TAG, "Applying WebView proxy: $host:$port")

        // Method 1: System properties (affects Java URLConnection)
        System.setProperty("http.proxyHost", host)
        System.setProperty("http.proxyPort", port.toString())
        System.setProperty("https.proxyHost", host)
        System.setProperty("https.proxyPort", port.toString())

        // Method 2: Set ProxySelector (broader coverage)
        try {
            java.net.ProxySelector.setDefault(object : java.net.ProxySelector() {
                override fun select(uri: java.net.URI): MutableList<java.net.Proxy> {
                    val proxy = java.net.Proxy(
                        java.net.Proxy.Type.HTTP,
                        java.net.InetSocketAddress(host, port)
                    )
                    return mutableListOf(proxy)
                }

                override fun connectFailed(
                    uri: java.net.URI?,
                    sa: java.net.SocketAddress?,
                    ioe: java.io.IOException?
                ) {
                    Log.w(TAG, "Proxy connect failed: ${ioe?.message}")
                }
            })
        } catch (e: Exception) {
            Log.w(TAG, "ProxySelector.setDefault failed: ${e.message}")
        }

        // Method 3: Reflection on WebView's internal setProxy (Chromium WebView)
        try {
            val setProxyMethod = WebView::class.java.getDeclaredMethod(
                "setProxy",
                String::class.java,
                Int::class.javaPrimitiveType,
                String::class.java
            )
            setProxyMethod.isAccessible = true
            setProxyMethod.invoke(webView, host, port, null)
            Log.d(TAG, "WebView setProxy via reflection: OK")
        } catch (e: NoSuchMethodException) {
            Log.d(TAG, "WebView.setProxy not available (modern Chromium), trying WebViewProvider...")
            try {
                val getProvider = WebView::class.java.getDeclaredMethod("getWebViewProvider")
                getProvider.isAccessible = true
                val provider = getProvider.invoke(webView)
                val providerSetProxy = provider.javaClass.getDeclaredMethod(
                    "setProxy",
                    String::class.java,
                    Int::class.javaPrimitiveType,
                    String::class.java
                )
                providerSetProxy.isAccessible = true
                providerSetProxy.invoke(provider, host, port, null)
                Log.d(TAG, "WebViewProvider setProxy via reflection: OK")
            } catch (e2: Exception) {
                Log.w(TAG, "All WebView proxy reflection failed: ${e2.message}")
            }
        } catch (e: Exception) {
            Log.w(TAG, "WebView proxy reflection error: ${e.message}")
        }
    }

    private fun clearWebViewProxy() {
        try {
            System.clearProperty("http.proxyHost")
            System.clearProperty("http.proxyPort")
            System.clearProperty("https.proxyHost")
            System.clearProperty("https.proxyPort")
        } catch (_: Exception) {}
    }

    @SuppressLint("SetJavaScriptEnabled")
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)

        proxySettings = ProxySettings(this)

        isTvDevice = isTv(this)

        // Detect WebView version for old-device handling
        webViewVersion = detectWebViewVersion()
        val isOldWebView = webViewVersion > 0 && webViewVersion < MIN_WEBVIEW_VERSION
        if (isOldWebView) {
            Log.w(TAG, "旧版WebView检测到: v$webViewVersion (推荐 >= $MIN_WEBVIEW_VERSION)")
        }

        // Keep screen on
        window.addFlags(WindowManager.LayoutParams.FLAG_KEEP_SCREEN_ON)
        // Fullscreen immersive mode for all devices (mobile + TV)
        @Suppress("DEPRECATION")
        window.decorView.systemUiVisibility = (
            View.SYSTEM_UI_FLAG_FULLSCREEN
                or View.SYSTEM_UI_FLAG_HIDE_NAVIGATION
                or View.SYSTEM_UI_FLAG_IMMERSIVE_STICKY
                or View.SYSTEM_UI_FLAG_LAYOUT_FULLSCREEN
                or View.SYSTEM_UI_FLAG_LAYOUT_HIDE_NAVIGATION
                or View.SYSTEM_UI_FLAG_LAYOUT_STABLE
        )

        // Root layout
        rootLayout = FrameLayout(this).apply {
            setBackgroundColor(Color.BLACK)
        }

        // Splash / brand image (shown immediately, fades out when page loads)
        splashView = ImageView(this).apply {
            layoutParams = FrameLayout.LayoutParams(
                if (isTvDevice) 300 else 200,
                if (isTvDevice) 300 else 200
            ).apply {
                gravity = Gravity.CENTER
            }
            setImageResource(R.mipmap.ic_launcher)
            scaleType = ImageView.ScaleType.FIT_CENTER
            alpha = 1.0f
            visibility = View.VISIBLE
        }

        // Settings button (gear icon) - shown on splash/error screen
        settingsBtn = Button(this).apply {
            text = "\u2699"  // gear unicode
            textSize = if (isTvDevice) 24f else 20f
            setTextColor(Color.parseColor("#FFCC00"))
            setBackgroundColor(Color.TRANSPARENT)
            layoutParams = FrameLayout.LayoutParams(
                if (isTvDevice) 80 else 60,
                if (isTvDevice) 80 else 60
            ).apply {
                gravity = Gravity.TOP or Gravity.END
                topMargin = if (isTvDevice) 40 else 20
                marginEnd = if (isTvDevice) 40 else 20
            }
            visibility = View.VISIBLE
            setOnClickListener { showProxyDialog() }
        }

        // Error text with scrollable content for long messages
        errorView = TextView(this).apply {
            text = "加载中..."
            setTextColor(Color.parseColor("#FFCC00"))
            textSize = if (isTvDevice) 20f else 16f
            typeface = Typeface.MONOSPACE
            gravity = Gravity.CENTER
            setPadding(40, 60, 40, 40)
            layoutParams = FrameLayout.LayoutParams(
                FrameLayout.LayoutParams.MATCH_PARENT,
                FrameLayout.LayoutParams.WRAP_CONTENT
            ).apply {
                gravity = Gravity.CENTER
            }
            visibility = View.GONE
        }

        // Progress bar
        progressBar = ProgressBar(this, null, android.R.attr.progressBarStyleHorizontal).apply {
            layoutParams = FrameLayout.LayoutParams(
                FrameLayout.LayoutParams.MATCH_PARENT,
                if (isTvDevice) 6 else 4
            ).apply {
                gravity = Gravity.TOP
            }
            max = 100
            progress = 0
            isIndeterminate = false
            visibility = View.VISIBLE
            isIndeterminate = true
        }

        // WebView
        webView = WebView(this).apply {
            layoutParams = FrameLayout.LayoutParams(
                FrameLayout.LayoutParams.MATCH_PARENT,
                FrameLayout.LayoutParams.MATCH_PARENT
            )
            id = View.generateViewId()

            // Remote debugging
            if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.KITKAT) {
                WebView.setWebContentsDebuggingEnabled(true)
            }

            // JS bridge
            addJavascriptInterface(JSConsoleBridge(), "AndroidBridge")

            settings.apply {
                javaScriptEnabled = true
                domStorageEnabled = true
                mediaPlaybackRequiresUserGesture = false
                loadWithOverviewMode = true
                useWideViewPort = true
                // Cache aggressively on old/slow devices
                cacheMode = if (isOldWebView) {
                    WebSettings.LOAD_CACHE_ELSE_NETWORK
                } else {
                    WebSettings.LOAD_DEFAULT
                }
                mixedContentMode = WebSettings.MIXED_CONTENT_ALWAYS_ALLOW
                databaseEnabled = true
                allowContentAccess = true
                allowFileAccess = false
                loadsImagesAutomatically = true
                blockNetworkImage = false
                // API 27+ only: safeBrowsingEnabled was added in Android 8.0
                // On Android 6.0 TVs, calling this directly causes NoSuchMethodError crash
                if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O_MR1) {
                    safeBrowsingEnabled = false
                }
                // Disable gesture-based scaling on TV to avoid accidental zoom
                builtInZoomControls = if (isOldWebView) false else !isTvDevice
                displayZoomControls = false
                setSupportZoom(!isTvDevice)

                // Font size slightly larger for TV
                if (isTvDevice) {
                    textZoom = 110
                }

                if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.LOLLIPOP) {
                    mixedContentMode = WebSettings.MIXED_CONTENT_ALWAYS_ALLOW
                }

                // Smart UA selection based on WebView version
                val baseUA = settings.userAgentString
                val uaList = generateFallbackUAs(baseUA)
                val selectedUA = if (isOldWebView && uaList.size > 1) {
                    // Use conservative UA for old WebViews
                    uaList[1]
                } else {
                    uaList[0]
                }
                userAgentString = selectedUA
                Log.d(TAG, "UA: $userAgentString | isTV: $isTvDevice | WebView v$webViewVersion")
            }

            webViewClient = object : WebViewClient() {
                override fun onPageStarted(view: WebView?, url: String?, favicon: Bitmap?) {
                    super.onPageStarted(view, url, favicon)
                    hasContentLoaded = false
                    progressBar.visibility = View.VISIBLE
                    progressBar.isIndeterminate = true
                    progressBar.progress = 0
                    errorView.visibility = View.GONE
                    Log.d(TAG, "Loading: $url")

                    // White screen detection timer
                    whiteScreenChecker?.let { mainHandler.removeCallbacks(it) }
                    whiteScreenChecker = Runnable {
                        if (!hasContentLoaded && loadAttempts < maxLoadAttempts) {
                            loadAttempts++
                            Log.w(TAG, "白屏检测触发 - 重试第 $loadAttempts 次")
                            progressBar.isIndeterminate = false
                            progressBar.progress = 10
                            if (loadAttempts <= maxLoadAttempts) {
                                // Rotate UA on each retry for old WebViews
                                if (isOldWebView && loadAttempts <= 3) {
                                    val uaList = generateFallbackUAs(settings.userAgentString)
                                    if (loadAttempts - 1 < uaList.size) {
                                        settings.userAgentString = uaList[loadAttempts - 1]
                                        Log.d(TAG, "Retry with UA[$loadAttempts]: ${settings.userAgentString}")
                                    }
                                }
                                view?.loadUrl(KVIDEO_URL)
                            }
                        } else if (!hasContentLoaded) {
                            Log.e(TAG, "白屏检测 - 已达最大重试次数")
                            val oldWebViewMsg = if (isOldWebView) {
                                "\n\n🔧 系统WebView版本过旧\n建议更新或安装新版WebView"
                            } else ""
                            showError(
                                "⚠️ 页面加载超时\n\n" +
                                "请检查：\n" +
                                "1️⃣ 网络连接是否正常\n" +
                                "2️⃣ VPN/代理是否已开启\n" +
                                "3️⃣ WebView是否需要更新$oldWebViewMsg\n\n" +
                                "点击右上角⚙配置代理\n" +
                                "或按确定键重试"
                            )
                        }
                    }
                    mainHandler.postDelayed(whiteScreenChecker!!, WHITE_SCREEN_TIMEOUT_MS)
                }

                override fun onPageFinished(view: WebView?, url: String?) {
                    super.onPageFinished(view, url)
                    Log.d(TAG, "Page finished: $url")

                    // Inject JS error capture + content-ready notification
                    // Using ES5-compatible syntax for old WebViews
                    view?.evaluateJavascript("""(function() {
    'use strict';
    try {
        // ES5-safe error handler
        window.onerror = function(msg, source, line, col, error) {
            var errMsg = '';
            if (typeof msg === 'string') { errMsg += msg; }
            if (source) { errMsg += ' @ ' + source + ':' + (line || 0); }
            try { AndroidBridge.error(errMsg); } catch(e) {}
            return true;
        };
        // Check if basic ES6 features exist (Promise is a good proxy)
        var hasPromise = (typeof Promise !== 'undefined');
        var hasSymbol  = (typeof Symbol !== 'undefined');
        var hasFetch   = (typeof fetch !== 'undefined');
        if (!hasPromise || !hasSymbol) {
            var missing = [];
            if (!hasPromise) missing.push('Promise');
            if (!hasSymbol)  missing.push('Symbol');
            if (!hasFetch)   missing.push('fetch');
            AndroidBridge.log('Old WebView: missing ' + missing.join(', '));
            // Still try to detect content - the site might have fallbacks
        }
        var checkContent = function() {
            var body = document.body;
            if (body && typeof body.innerHTML === 'string' && body.innerHTML.length > 50) {
                try { AndroidBridge.pageReady(); } catch(e) {}
                return true;
            }
            return false;
        };
        if (checkContent()) return;
        var retries = 0;
        var maxRetries = 90;  // 45 seconds for slow devices
        var timer = setInterval(function() {
            if (checkContent() || retries++ >= maxRetries) {
                clearInterval(timer);
                if (retries >= maxRetries) {
                    try { AndroidBridge.error('Page render timeout') } catch(e) {
                        // Fallback if encoding fails on old WebView
                        try { AndroidBridge.error('') } catch(er) {}
                    }
                }
            }
        }, 500);
        // Also try to detect if body is empty after page load
        setTimeout(function() {
            if (!checkContent()) {
                try { AndroidBridge.log(''); } catch(e) {}
            }
        }, 10000);
    } catch(e) {
        // Last resort - can't even inject, WebView is extremely old
        try { AndroidBridge.error('OLD_WEBVIEW'); } catch(er) {
            try { AndroidBridge.error(''); } catch(er2) {}
        }
    }
})();""".trimIndent(), null)

                    // Auto-hide progress bar after a delay
                    if (progressBar.progress >= 80) {
                        progressBar.postDelayed({
                            progressBar.visibility = View.GONE
                        }, 300)
                    }
                }

                override fun onRenderProcessGone(view: WebView?, detail: RenderProcessGoneDetail?): Boolean {
                    Log.e(TAG, "WebView 渲染进程崩溃！didCrash=${detail?.didCrash()}")
                    showError("WebView 渲染进程崩溃\n请更新 WebView 组件或重启应用")
                    return true
                }

                override fun onReceivedSslError(
                    view: WebView?,
                    handler: SslErrorHandler?,
                    error: SslError?
                ) {
                    Log.w(TAG, "SSL 错误: ${error?.toString()}")
                    handler?.proceed()
                }

                override fun onReceivedError(
                    view: WebView?,
                    request: WebResourceRequest?,
                    error: WebResourceError?
                ) {
                    val description = if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.M) {
                        error?.description?.toString() ?: "未知错误"
                    } else {
                        "未知错误"
                    }
                    Log.e(TAG, "加载错误: $description (url=${request?.url})")

                    if (request?.isForMainFrame == true) {
                        view?.stopLoading()
                        if (loadAttempts < maxLoadAttempts) {
                            loadAttempts++
                            Log.d(TAG, "重试第 $loadAttempts 次...")
                            showError("加载失败 ($description)\n${maxLoadAttempts - loadAttempts + 1} 秒后重试...")
                            view?.postDelayed({
                                errorView.visibility = View.GONE
                                // Try different UA on retry
                                if (isOldWebView && loadAttempts <= 3) {
                                    val uaList = generateFallbackUAs(settings.userAgentString)
                                    if (loadAttempts - 1 < uaList.size) {
                                        settings.userAgentString = uaList[loadAttempts - 1]
                                        Log.d(TAG, "Error retry with UA[$loadAttempts]: ${settings.userAgentString}")
                                    }
                                }
                                view.loadUrl(KVIDEO_URL)
                            }, 2000)
                        } else {
                            val oldWebViewMsg = if (isOldWebView) {
                                "\n\n🔧 提示：系统WebView版本过旧\n建议在应用商店搜索更新\n\"Android System WebView\""
                            } else ""
                            showError(
                                "⚠️ 页面加载失败\n\n$description$oldWebViewMsg\n\n" +
                                "请检查：\n" +
                                "1️⃣ 网络连接是否正常\n" +
                                "2️⃣ VPN/代理是否已开启\n" +
                                "3️⃣ 网站是否正常运行\n\n" +
                                "点击右上角⚙配置代理\n" +
                                "或按确定键重试"
                            )
                        }
                    }
                }

                override fun shouldOverrideUrlLoading(
                    view: WebView?,
                    request: WebResourceRequest?
                ): Boolean {
                    return false
                }
            }

            webChromeClient = object : WebChromeClient() {
                override fun onProgressChanged(view: WebView?, newProgress: Int) {
                    if (progressBar.isIndeterminate && newProgress > 5) {
                        progressBar.isIndeterminate = false
                    }
                    progressBar.progress = newProgress
                    if (newProgress >= 95) {
                        progressBar.postDelayed({
                            progressBar.visibility = View.GONE
                        }, 200)
                    }
                }

                override fun onConsoleMessage(msg: ConsoleMessage?): Boolean {
                    val level = when (msg?.messageLevel()) {
                        ConsoleMessage.MessageLevel.ERROR -> "E"
                        ConsoleMessage.MessageLevel.WARNING -> "W"
                        else -> "D"
                    }
                    Log.d(TAG, "[CONSOLE $level] ${msg?.message()} (${msg?.sourceId()}:${msg?.lineNumber()})")
                    return true
                }
            }

            // Apply proxy BEFORE loading if configured
            applyProxyToWebView()

            // Show WebView version warning if too old
            if (isOldWebView) {
                showError(
                    "⚠️ 系统 WebView 版本过旧 (v$webViewVersion)\n\n" +
                    "当前电视的 WebView 版本较旧\n" +
                    "网站可能无法正常渲染\n\n" +
                    "建议操作：\n" +
                    "1️⃣ 打开应用商店搜索更新\n" +
                    "   \"Android System WebView\"\n" +
                    "2️⃣ 或安装当贝市场/沙发管家\n" +
                    "   更新系统组件\n" +
                    "3️⃣ 直接点确定尝试加载\n\n" +
                    "白屏等待时间已延长至60秒\n" +
                    "并会自动切换UA重试" + "\n\n" +
                    "\u23CE 确定键尝试加载"
                )
                // Still try to load after showing warning
                postDelayed({
                    if (!hasContentLoaded) {
                        errorView.visibility = View.GONE
                        loadUrl(KVIDEO_URL)
                    }
                }, 8000)
            } else {
                // Check network before loading
                if (!isNetworkAvailable()) {
                    showError(
                        "⚠️ 无网络连接\n\n" +
                        "请检查：\n" +
                        "1️⃣ WiFi 是否已连接\n" +
                        "2️⃣ 路由器是否正常工作\n" +
                        "3️⃣ VPN/代理是否已开启\n\n" +
                        "连接网络后按确定键重试"
                    )
                } else {
                    loadUrl(KVIDEO_URL)
                }
            }
        }

        rootLayout.addView(webView)
        rootLayout.addView(splashView)
        rootLayout.addView(progressBar)
        rootLayout.addView(errorView)
        rootLayout.addView(settingsBtn)
        setContentView(rootLayout)
    }

    private fun showError(message: String) {
        errorView.apply {
            text = message
            setTextColor(Color.parseColor("#FFCC00"))
            visibility = View.VISIBLE
        }
        progressBar.visibility = View.GONE
        splashView.visibility = View.VISIBLE
        settingsBtn.visibility = View.VISIBLE
    }

    private fun showProxyDialog() {
        val dialogView = layoutInflater.inflate(R.layout.dialog_proxy_settings, null)

        val switchEnabled = dialogView.findViewById<SwitchCompat>(R.id.proxyEnabled)
        val hostInput = dialogView.findViewById<EditText>(R.id.proxyHost)
        val portInput = dialogView.findViewById<EditText>(R.id.proxyPort)

        // Load current settings
        switchEnabled.isChecked = proxySettings.enabled
        hostInput.setText(proxySettings.host)
        portInput.setText(proxySettings.port.toString())

        val dialog = AlertDialog.Builder(this, android.R.style.Theme_Material_Dialog)
            .setView(dialogView)
            .setCancelable(false)
            .create()

        dialogView.findViewById<Button>(R.id.btnSave).setOnClickListener {
            proxySettings.enabled = switchEnabled.isChecked
            proxySettings.host = hostInput.text.toString().trim()
            val portStr = portInput.text.toString().trim()
            if (portStr.isNotEmpty()) {
                proxySettings.port = portStr.toIntOrNull() ?: 7890
            }

            Log.d(TAG, "Proxy settings saved: ${proxySettings}")

            // Apply proxy and retry
            applyProxyToWebView()
            retryLoad()
            dialog.dismiss()
        }

        dialogView.findViewById<Button>(R.id.btnCancel).setOnClickListener {
            dialog.dismiss()
        }

        dialog.window?.setBackgroundDrawable(
            GradientDrawable().apply {
                setColor(Color.parseColor("#1A1A1A"))
                setCornerRadius(16f)
            }
        )
        dialog.show()
    }

    // TV remote D-pad center → Enter
    override fun onKeyDown(keyCode: Int, event: KeyEvent?): Boolean {
        if (isTvDevice && keyCode == KeyEvent.KEYCODE_DPAD_CENTER) {
            if (errorView.visibility == View.VISIBLE || !hasContentLoaded) {
                retryLoad()
                return true
            }
            webView.dispatchKeyEvent(KeyEvent(KeyEvent.ACTION_DOWN, KeyEvent.KEYCODE_ENTER))
            return true
        }
        return super.onKeyDown(keyCode, event)
    }

    override fun onKeyUp(keyCode: Int, event: KeyEvent?): Boolean {
        if (isTvDevice && keyCode == KeyEvent.KEYCODE_DPAD_CENTER) {
            if (errorView.visibility == View.VISIBLE || !hasContentLoaded) {
                return true
            }
            webView.dispatchKeyEvent(KeyEvent(KeyEvent.ACTION_UP, KeyEvent.KEYCODE_ENTER))
            return true
        }
        return super.onKeyUp(keyCode, event)
    }

    private fun retryLoad() {
        loadAttempts = 0
        hasContentLoaded = false
        errorView.visibility = View.GONE
        splashView.visibility = View.VISIBLE
        progressBar.visibility = View.VISIBLE
        progressBar.isIndeterminate = true
        applyProxyToWebView()
        webView.loadUrl(KVIDEO_URL)
    }

    @Deprecated("Use OnBackPressedDispatcher")
    override fun onBackPressed() {
        if (webView.canGoBack()) {
            webView.goBack()
        } else {
            @Suppress("DEPRECATION")
            super.onBackPressed()
        }
    }

    override fun onDestroy() {
        whiteScreenChecker?.let { mainHandler.removeCallbacks(it) }
        webView.destroy()
        super.onDestroy()
    }
}
