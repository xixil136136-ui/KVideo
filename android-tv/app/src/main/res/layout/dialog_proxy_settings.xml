<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="代理设置"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="适用于中国大陆用户访问海外网站，填写你代理工具的地址"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="20dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/proxyEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="启用代理"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="代理地址"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/proxyHost"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="127.0.0.1"
            android:inputType="text|textNoSuggestions"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="#333333"
            android:paddingHorizontal="12dp"
            android:singleLine="true"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="端口"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/proxyPort"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="7890"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="#333333"
            android:paddingHorizontal="12dp"
            android:singleLine="true"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💡 常用代理工具地址"
            android:textColor="#888888"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clash/V2Ray: 127.0.0.1:7890\nSSR: 127.0.0.1:1080\nSurfboard: 127.0.0.1:7890"
            android:textColor="#666666"
            android:textSize="11sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="取消"
                android:textColor="#888888"
                android:background="@android:color/transparent"
                android:minWidth="80dp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="保存"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"
                android:minWidth="80dp"
                android:layout_marginStart="12dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
